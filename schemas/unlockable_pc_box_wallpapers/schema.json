{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cobblemon-schema.local/unlockable_pc_box_wallpapers/schema.json",
  "title": "Cobblemon Unlockable PC Box Wallpaper",
  "type": "object",
  "properties": {
    "enabled": {
      "type": "boolean"
    },
    "displayName": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "texture": {
      "$ref": "../_shared/defs/identifiers.schema.json#/$defs/identifier"
    }
  },
  "required": [
    "enabled",
    "texture"
  ],
  "additionalProperties": false
}
