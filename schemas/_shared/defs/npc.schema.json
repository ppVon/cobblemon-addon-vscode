{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cobblemon-schema.local/_shared/defs/npc.schema.json",
  "title": "Cobblemon Shared NPC Definitions",
  "type": "object",
  "$defs": {
    "variableDefinition": {
      "type": "object",
      "properties": {
        "variableName": {
          "type": "string"
        },
        "category": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "displayName": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "description": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "type": {
          "type": "string"
        },
        "defaultValue": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "boolean"
            },
            {
              "type": "number"
            },
            {
              "type": "integer"
            }
          ]
        }
      },
      "required": [
        "variableName",
        "displayName",
        "description",
        "type",
        "defaultValue"
      ],
      "additionalProperties": false
    }
  }
}
