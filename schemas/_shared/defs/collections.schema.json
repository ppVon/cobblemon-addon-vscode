{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cobblemon-schema.local/_shared/defs/collections.schema.json",
  "title": "Cobblemon Shared Collections",
  "type": "object",
  "$defs": {
    "stringList": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stringIntMap": {
      "type": "object",
      "additionalProperties": {
        "type": "integer"
      }
    },
    "stringNumberMap": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    },
    "stringStringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
