{
  "name": "cobblemon-schema-tools",
  "displayName": "Cobblemon Schema Tools",
  "description": "Workspace-wide Cobblemon data validation, asset linkage diagnostics, and guided builders for Cobblemon addon content.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ppVon/cobblemon-addon-vscode"
  },
  "icon": "cobblemon-schema-tools.png",
  "version": "0.9.7",
  "publisher": "ppVon",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:json",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onCommand:cobblemonSchemaTools.scaffoldAbilityFile",
    "onCommand:cobblemonSchemaTools.insertAbilityCallback",
    "onCommand:cobblemonSchemaTools.insertMoveCallback",
    "onCommand:cobblemonSchemaTools.validateWorkspace",
    "onCommand:cobblemonSchemaTools.generatePackMcmeta",
    "onCommand:cobblemonSchemaTools.packageAddon",
    "onCommand:cobblemonSchemaTools.scaffoldMoveFile",
    "onCommand:cobblemonSchemaTools.scaffoldPokemonAssets",
    "onCommand:cobblemonSchemaTools.scaffoldDataFile",
    "onCommand:cobblemonSchemaTools.generateSpawnPoolWorld",
    "onCommand:cobblemonSchemaTools.installTypes"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cobblemonSchemaTools.validateWorkspace",
        "title": "Cobblemon: Validate Workspace Data"
      },
      {
        "command": "cobblemonSchemaTools.insertMoveCallback",
        "title": "Cobblemon: Insert Move Callback"
      },
      {
        "command": "cobblemonSchemaTools.insertAbilityCallback",
        "title": "Cobblemon: Insert Ability Callback"
      },
      {
        "command": "cobblemonSchemaTools.generatePackMcmeta",
        "title": "Cobblemon: Generate pack.mcmeta"
      },
      {
        "command": "cobblemonSchemaTools.installTypes",
        "title": "Cobblemon: Install TypeScript Type Definitions"
      },
      {
        "command": "cobblemonSchemaTools.packageAddon",
        "title": "Cobblemon: Package Addon Zip"
      },
      {
        "command": "cobblemonSchemaTools.scaffoldAbilityFile",
        "title": "Cobblemon: Ability Builder Form"
      },
      {
        "command": "cobblemonSchemaTools.scaffoldMoveFile",
        "title": "Cobblemon: Move Builder Form"
      },
      {
        "command": "cobblemonSchemaTools.scaffoldPokemonAssets",
        "title": "Cobblemon: Pokemon Builder Form"
      },
      {
        "command": "cobblemonSchemaTools.scaffoldDataFile",
        "title": "Cobblemon: Scaffold Data JSON File"
      },
      {
        "command": "cobblemonSchemaTools.generateSpawnPoolWorld",
        "title": "Cobblemon: Generate Spawn Pool World"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "cobblemonSchemaTools.insertAbilityCallback",
          "when": "editorTextFocus && cobblemonSchemaTools.inAbilityFile"
        },
        {
          "command": "cobblemonSchemaTools.insertMoveCallback",
          "when": "editorTextFocus && cobblemonSchemaTools.inMoveFile"
        }
      ],
      "editor/context": [
        {
          "command": "cobblemonSchemaTools.insertAbilityCallback",
          "when": "editorTextFocus && cobblemonSchemaTools.inAbilityFile",
          "group": "cobblemon@11"
        },
        {
          "command": "cobblemonSchemaTools.insertMoveCallback",
          "when": "editorTextFocus && cobblemonSchemaTools.inMoveFile",
          "group": "cobblemon@10"
        }
      ]
    },
    "configuration": {
      "title": "Cobblemon Schema Tools",
      "properties": {
        "cobblemonSchemaTools.strictAssetNaming": {
          "type": "boolean",
          "default": false,
          "description": "When enabled, naming/linking mismatches in resolver/poser filenames are reported as errors instead of warnings."
        },
        "cobblemonSchemaTools.strictWorkspaceValidation": {
          "type": "boolean",
          "default": true,
          "description": "When enabled, workspace-level validation findings that are normally warnings are escalated to errors."
        },
        "cobblemonSchemaTools.enableWorkspaceValidation": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic workspace-wide Cobblemon JSON validation and linkage diagnostics."
        },
        "cobblemonSchemaTools.useTypescriptForMoves": {
          "type": "boolean",
          "default": false,
          "description": "Use Typescript for Moves? When enabled, the move builder generates .ts move files and writes a hidden helper type file for MoveData callback typing."
        },
        "cobblemonSchemaTools.useTypescriptForAbilities": {
          "type": "boolean",
          "default": false,
          "description": "Use Typescript for Abilities? When enabled, the ability builder generates .ts ability files and writes a hidden helper type file for AbilityData callback typing."
        },
        "cobblemonSchemaTools.warnOnPokemonAssetFolderNaming": {
          "type": "boolean",
          "default": true,
          "description": "When enabled, resolver and pokemon poser files whose parent folder does not follow the usual <dex>_<species> naming pattern are reported as warnings."
        }
      }
    }
  },
  "scripts": {
    "build": "npm run check && node ./scripts/clean-dist.mjs && node ./scripts/build-extension.mjs",
    "watch": "node ./scripts/build-extension.mjs --watch",
    "check": "tsc -p . --noEmit",
    "refresh:cobblemon-default-index": "node ./scripts/generate-cobblemon-default-index.mjs",
    "package": "npm run build && npx @vscode/vsce package --no-dependencies"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.6.3"
  }
}
